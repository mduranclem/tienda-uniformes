generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Banners (carrusel home) ───────────────────────────────────────────────────
model BannerSlide {
  id        String   @id @default(cuid())
  url       String
  titulo    String?
  orden     Int      @default(0)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ── Colegios ──────────────────────────────────────────────────────────────────
model Colegio {
  id        String     @id @default(cuid())
  nombre    String
  slug      String     @unique
  logo      String?
  activo    Boolean    @default(true)
  createdAt DateTime   @default(now())

  productos Producto[]
  cupones   Cupon[]
  alumnos   Alumno[]
}

// ── Categorías ────────────────────────────────────────────────────────────────
model Categoria {
  id        String   @id @default(cuid())
  nombre    String   @unique
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now())
}

// ── Productos ─────────────────────────────────────────────────────────────────
model Producto {
  id           String         @id @default(cuid())
  nombre       String
  descripcion  String?
  tipo         String         @default("REMERA")
  precio       Decimal        @db.Decimal(10, 2)
  colegioId    String?
  colegio      Colegio?       @relation(fields: [colegioId], references: [id])
  precioOferta Decimal?       @db.Decimal(10, 2)
  cuotas       Int?
  activo       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  imagenes     ProductImage[]
  variantes    Variante[]
  colores      ProductoColor[]
  itemsOrden   ItemOrden[]
  itemsCarrito ItemCarrito[]
  cupones      Cupon[]
}

model ProductImage {
  id         String   @id @default(cuid())
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  url        String
  orden      Int      @default(0)
  alt        String?
  color      String?  // null = imagen genérica (se muestra para todos los colores)
}

// ── Colores por producto ──────────────────────────────────────────────────────
model ProductoColor {
  id         String   @id @default(cuid())
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  nombre     String
  createdAt  DateTime @default(now())

  @@unique([productoId, nombre])
}

// ── Variantes ─────────────────────────────────────────────────────────────────
model Variante {
  id           String        @id @default(cuid())
  productoId   String
  producto     Producto      @relation(fields: [productoId], references: [id], onDelete: Cascade)
  talle        String
  color        String?
  stock        Int           @default(0)
  precio       Decimal?      @db.Decimal(10, 2)
  sku          String?       @unique

  itemsOrden   ItemOrden[]
  itemsCarrito ItemCarrito[]

  @@unique([productoId, talle, color])
}

// ── Usuarios ──────────────────────────────────────────────────────────────────
model Usuario {
  id        String     @id
  email     String     @unique
  nombre    String?
  telefono  String?
  rol       RolUsuario @default(CLIENTE)
  createdAt DateTime   @default(now())

  ordenes  Orden[]
  carritos Carrito[]
  alumnos  Alumno[]
}

enum RolUsuario {
  CLIENTE
  ADMIN
}

// ── Carritos ──────────────────────────────────────────────────────────────────
model Carrito {
  id        String   @id @default(cuid())
  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])
  sessionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ItemCarrito[]

  @@index([sessionId])
}

model ItemCarrito {
  id         String   @id @default(cuid())
  carritoId  String
  carrito    Carrito  @relation(fields: [carritoId], references: [id], onDelete: Cascade)
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id])
  varianteId String
  variante   Variante @relation(fields: [varianteId], references: [id])
  cantidad   Int
  precioUnit Decimal  @db.Decimal(10, 2)

  @@unique([carritoId, varianteId])
}

// ── Órdenes ───────────────────────────────────────────────────────────────────
model Orden {
  id             String      @id @default(cuid())
  numero         Int         @default(autoincrement())
  usuarioId      String?
  usuario        Usuario?    @relation(fields: [usuarioId], references: [id])
  emailGuest     String?
  nombreGuest    String?
  telefonoGuest  String?
  estado         EstadoOrden @default(PENDIENTE)
  subtotal       Decimal     @db.Decimal(10, 2)
  descuento      Decimal     @default(0) @db.Decimal(10, 2)
  costoEnvio     Decimal     @default(0) @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  metodoPago     String?
  mpPaymentId    String?
  mpPreferenceId String?
  cuponId        String?
  cupon          Cupon?      @relation(fields: [cuponId], references: [id])
  entregaId      String?
  entrega        Entrega?    @relation(fields: [entregaId], references: [id])
  domicilio      Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  items    ItemOrden[]
  historial HistorialOrden[]
}

enum EstadoOrden {
  PENDIENTE
  PAGADA
  PREPARANDO
  LISTA
  ENTREGADA
  CANCELADA
}

model ItemOrden {
  id         String   @id @default(cuid())
  ordenId    String
  orden      Orden    @relation(fields: [ordenId], references: [id])
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id])
  varianteId String
  variante   Variante @relation(fields: [varianteId], references: [id])
  cantidad   Int
  precioUnit Decimal  @db.Decimal(10, 2)
  subtotal   Decimal  @db.Decimal(10, 2)
}

model HistorialOrden {
  id        String      @id @default(cuid())
  ordenId   String
  orden     Orden       @relation(fields: [ordenId], references: [id])
  estado    EstadoOrden
  nota      String?
  createdAt DateTime    @default(now())
}

// ── Entrega ───────────────────────────────────────────────────────────────────
model Entrega {
  id      String      @id @default(cuid())
  tipo    TipoEntrega
  nombre  String
  costo   Decimal     @default(0) @db.Decimal(10, 2)
  activo  Boolean     @default(true)

  ordenes Orden[]
}

enum TipoEntrega {
  ENVIO
  RETIRO
}

// ── Promociones ───────────────────────────────────────────────────────────────
model Promocion {
  id         String        @id @default(cuid())
  nombre     String
  tipo       TipoDescuento
  valor      Decimal       @db.Decimal(10, 2)
  aplicaA    AplicaA
  colegioId  String?
  productoId String?
  activo     Boolean       @default(true)
  desde      DateTime?
  hasta      DateTime?
  createdAt  DateTime      @default(now())
}

model Cupon {
  id           String        @id @default(cuid())
  codigo       String        @unique
  tipo         TipoDescuento
  valor        Decimal       @db.Decimal(10, 2)
  aplicaA      AplicaA
  colegioId    String?
  colegio      Colegio?      @relation(fields: [colegioId], references: [id])
  productoId   String?
  producto     Producto?     @relation(fields: [productoId], references: [id])
  usosMax      Int?
  usosActuales Int           @default(0)
  minimoCompra Decimal?      @db.Decimal(10, 2)
  activo       Boolean       @default(true)
  desde        DateTime?
  hasta        DateTime?
  createdAt    DateTime      @default(now())

  ordenes Orden[]
}

enum TipoDescuento {
  PORCENTAJE
  MONTO_FIJO
}

enum AplicaA {
  TODO
  COLEGIO
  PRODUCTO
}

// ── Alumnos ───────────────────────────────────────────────────────────────────
model Alumno {
  id        String   @id @default(cuid())
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  nombre    String
  colegioId String?
  colegio   Colegio? @relation(fields: [colegioId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  talles AlumnoTalle[]

  @@index([usuarioId])
}

model AlumnoTalle {
  id         String @id @default(cuid())
  alumnoId   String
  alumno     Alumno @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  tipoPrenda String
  talle      String

  @@unique([alumnoId, tipoPrenda])
}
